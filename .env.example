# ─────────────────────────────────────────────────────────
# Pramaan A2A — Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values you need.
#
# ⚡ NO API KEYS ARE REQUIRED for default mode.
# The LangChain agents use a deterministic GenericFakeChatModel.
# Only set these if you want to use a real LLM provider.
# ─────────────────────────────────────────────────────────

# ── OpenAI (pip install langchain-openai) ──
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o

# ── Anthropic (pip install langchain-anthropic) ──
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Azure OpenAI (pip install langchain-openai) ──
# AZURE_OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-06-01

# ── Google Generative AI (pip install langchain-google-genai) ──
# GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Server Config ──
# HOST=0.0.0.0
# PORT=8000

# ── Admin Console (Docker only) ──
# API_BASE=http://handshakeos-api:8000

