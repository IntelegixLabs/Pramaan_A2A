# ─────────────────────────────────────────────────────────
# Pramaan A2A — Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your API key.
#
# The LLM factory auto-detects which provider to use based
# on which API key is set. Priority: OpenAI → Google → Anthropic.
#
# If NO key is set, agents run in deterministic mock mode
# (GenericFakeChatModel — no API calls made).
# ─────────────────────────────────────────────────────────

# ── OpenAI (recommended) ──
# pip install langchain-openai
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# ── Google Gemini ──
# pip install langchain-google-genai
# GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_MODEL=gemini-2.0-flash

# ── Anthropic ──
# pip install langchain-anthropic
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# -------------------------------------------------------------------
# Observability & Monitoring
# -------------------------------------------------------------------
# Add Langfuse keys to enable comprehensive tracing of all LLM and tool calls.
LANGFUSE_SECRET_KEY=""
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_HOST="https://cloud.langfuse.com"

# ── Azure OpenAI ──
# pip install langchain-openai
# AZURE_OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-06-01

## ── Server Config ──
#HOST=0.0.0.0
#PORT=8200
#
## ── Admin Console (Docker only) ──
#API_BASE=http://handshakeos-api:8200
